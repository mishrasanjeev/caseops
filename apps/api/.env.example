CASEOPS_ENV=local
CASEOPS_API_NAME=CaseOps API
CASEOPS_API_VERSION=0.1.0
CASEOPS_API_HOST=0.0.0.0
CASEOPS_API_PORT=8000
CASEOPS_API_DOCS_ENABLED=true
CASEOPS_PUBLIC_APP_URL=http://localhost:3000
CASEOPS_DATABASE_URL=postgresql+psycopg://caseops:caseops@127.0.0.1:5432/caseops
# Local CaseOps runtime should use Postgres 17 + pgvector to match production.
CASEOPS_AUTH_SECRET=change-me-change-me-change-me-2026
# Required: set to a 32+ byte secret in staging/production. The default above
# is rejected at startup whenever CASEOPS_ENV is staging/production/prod.
CASEOPS_ACCESS_TOKEN_TTL_MINUTES=120
CASEOPS_AUTO_MIGRATE=true
CASEOPS_DOCUMENT_STORAGE_BACKEND=local
CASEOPS_DOCUMENT_STORAGE_PATH=./storage/documents
CASEOPS_DOCUMENT_STORAGE_CACHE_PATH=./storage/document-cache
CASEOPS_DOCUMENT_STORAGE_GCS_BUCKET=
CASEOPS_DOCUMENT_STORAGE_GCS_PREFIX=documents
CASEOPS_GCP_PROJECT_ID=
CASEOPS_TESSERACT_COMMAND=
CASEOPS_DOCUMENT_WORKER_POLL_INTERVAL_SECONDS=10
CASEOPS_DOCUMENT_WORKER_BATCH_SIZE=5
CASEOPS_DOCUMENT_PROCESSING_STALE_AFTER_MINUTES=15
CASEOPS_DOCUMENT_RETRY_AFTER_HOURS=6
CASEOPS_DOCUMENT_REINDEX_AFTER_HOURS=168
CASEOPS_DOCUMENT_REPROCESSING_BATCH_SIZE=10
